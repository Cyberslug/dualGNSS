{
  "name": "dualGNSS",
  "version": "0.1.0",
  "description": "CASIC and u-blox M6-M10 GNSS library for ESP32 with auto-baud detection and CRSF payload output.",
  "keywords": [
    "gnss",
    "gps",
    "ublox",
    "u-blox",
    "casic",
    "esp32",
    "crsf",
    "elrs",
    "navigation"
  ],
  "homepage": "https://github.com/Cyberslug/dualGNSS",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cyberslug/dualGNSS.git"
  },
  "license": "GPL V3",
  "authors": [
    {
      "name": "D.Gamble (Github: Cyberslug)",
      "maintainer": true
    }
  ],
  "frameworks": "arduino",
  "platforms": "espressif32",
  "build": {
    "srcDir": "src"
  },
  "examples": [
    {
      "name": "UbxFullSetup",
      "base": "examples/UbxFullSetup",
      "files": ["UbxFullSetup.ino"]
    },
    {
      "name": "CasicFullSetup",
      "base": "examples/CasicFullSetup",
      "files": ["CasicFullSetup.ino"]
    }
  ]
}
